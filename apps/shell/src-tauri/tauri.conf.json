{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RaioPDF",
  "version": "../package.json",
  "identifier": "me.macrify.raiopdf",
  "build": {
    "beforeDevCommand": "pnpm --dir ../ui dev --host 127.0.0.1 --port 5173 --strictPort",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm --dir ../ui build",
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RaioPDF",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:*; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "publisher": "Macrify LLC",
    "homepage": "https://raio.macrify.me",
    "copyright": "Copyright (c) 2026 Macrify LLC",
    "license": "GPL-3.0-only",
    "licenseFile": "../../../installer/RAIOPDF-LICENSE-NOTICES.txt",
    "category": "Productivity",
    "shortDescription": "Free, local desktop PDF suite for law firms.",
    "longDescription": "RaioPDF is a free, fully local PDF suite for law firms. It runs on your computer and ships as open-source software under GPL-3.0 with bundled third-party components under their own licenses.",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": [
      "payload/**/*"
    ],
    "windows": {
      "nsis": {
        "headerImage": "../../../installer/artwork/nsis-header.bmp",
        "sidebarImage": "../../../installer/artwork/nsis-sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": [
          "English"
        ],
        "compression": "lzma"
      },
      "wix": {
        "bannerPath": "../../../installer/artwork/wix-banner.bmp",
        "dialogImagePath": "../../../installer/artwork/wix-dialog.bmp"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Macrify-LLC/raiopdf/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFFRTFBNkE1RTRDQkIyQUEKUldTcXNzdmtwYWJoSGtpclh5QnAvSTlxalZCZ25FL3hqS0IrNEZRNmFFcWRzRFgwVitsZmprRkgK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
