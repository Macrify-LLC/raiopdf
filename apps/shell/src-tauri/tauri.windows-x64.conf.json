{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RaioPDF",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "decorations": false,
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "resources": {
      "payload/windows-x64": "payload"
    },
    "windows": {
      "allowDowngrades": false,
      "nsis": {
        "headerImage": "../../../installer/artwork/nsis-header.bmp",
        "sidebarImage": "../../../installer/artwork/nsis-sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English"],
        "compression": "lzma"
      }
    }
  },
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
