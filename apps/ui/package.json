{
  "name": "@raiopdf/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm sync:pdfjs-assets && vite",
    "build": "pnpm sync:pdfjs-assets && tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:smoke": "playwright test",
    "test:canary": "playwright test -c playwright.canary.config.ts",
    "sync:pdfjs-assets": "node scripts/sync-pdfjs-assets.mjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "@raiopdf/engine-api": "workspace:*",
    "@raiopdf/engine-local": "workspace:*",
    "@raiopdf/engine-pdf-lib": "workspace:*",
    "@raiopdf/engine-sidecar": "workspace:*",
    "@raiopdf/help-content": "workspace:*",
    "@raiopdf/rules": "workspace:*",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "jsdom": "^29.1.1",
    "pdf-lib": "^1.17.1"
  }
}
