{
  "name": "raiopdf",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter @raiopdf/ui dev",
    "dev:shell": "pnpm --filter @raiopdf/shell tauri dev",
    "build": "pnpm -r build",
    "build:shell": "pnpm --filter @raiopdf/shell tauri build",
    "engine:vendor": "bash engine/vendor.sh",
    "engine:build": "bash engine/build.sh",
    "engine:verify": "bash engine/verify-live.sh",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.7.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
