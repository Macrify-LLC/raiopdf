# macOS arm64 payload component pins (URL + SHA256).
#
# Every macOS payload component is pinned to an exact source and SHA256. The
# assembler (assemble-macos-arm64.sh) refuses to proceed on any checksum
# mismatch. Never place a Windows fallback URL in this file: a missing macOS
# component must fail the macOS assembly, not silently substitute a foreign
# binary.
#
# Relocatability contract: the bundled Python comes from python-build-standalone
# (relocatable by design); the native OCR tools (Ghostscript, qpdf, Tesseract)
# are BUILT FROM PINNED SOURCE into self-contained arm64 binaries that link only
# system libraries (/usr/lib, /System). Homebrew binaries are never shipped.

# --- Temurin JRE 25 (aarch64_mac) — bundled JVM that runs the Stirling engine ---
TEMURIN_JRE_VERSION=25.0.3+9
TEMURIN_JRE_URL=https://github.com/adoptium/temurin25-binaries/releases/download/jdk-25.0.3%2B9/OpenJDK25U-jre_aarch64_mac_hotspot_25.0.3_9.tar.gz
TEMURIN_JRE_SHA256=287cc80077dc2ffd0e5733ba238f92206a84c26bef33e6881a23c213e4c35af4

# --- Temurin JDK 25 (aarch64_mac) — builds the Stirling engine JAR when no
#     system JDK is available on the build host. Not shipped in the payload. ---
TEMURIN_JDK_VERSION=25.0.3+9
TEMURIN_JDK_URL=https://github.com/adoptium/temurin25-binaries/releases/download/jdk-25.0.3%2B9/OpenJDK25U-jdk_aarch64_mac_hotspot_25.0.3_9.tar.gz
TEMURIN_JDK_SHA256=7baab4d69a15554e119b86ff78d40e3fdc28819b5b322955c913cebfe3f6a37c

# --- CPython via python-build-standalone (aarch64-apple-darwin, install_only) ---
#     No macOS "embed" build exists (unlike Windows); python-build-standalone's
#     install_only tarball is relocatable out of the box.
PYTHON_STANDALONE_VERSION=3.13.14
PYTHON_STANDALONE_RELEASE=20260623
PYTHON_STANDALONE_URL=https://github.com/astral-sh/python-build-standalone/releases/download/20260623/cpython-3.13.14+20260623-aarch64-apple-darwin-install_only.tar.gz
PYTHON_STANDALONE_SHA256=804c86c8665b18eb0df5070a79d828229018d145baea38a71a5c74c03f9b11d4
PYTHON_ABI=cp313
PYTHON_VERSION=3.13

# --- Node.js runtime (darwin-arm64) — bundled runtime for the MCP connector ---
NODE_RUNTIME_VERSION=24.18.0
NODE_RUNTIME_URL=https://nodejs.org/download/release/v24.18.0/node-v24.18.0-darwin-arm64.tar.gz
NODE_RUNTIME_SHA256=e1a97e14c99c803e96c7339403282ea05a499c32f8d83defe9ef5ec66f979ed1

# --- OCRmyPDF (installed into the bundled Python via hash-pinned wheels) ---
OCRMYPDF_VERSION=17.8.0
OCRMYPDF_REQUIREMENTS=installer/ocrmypdf-macos-requirements.txt
OCRMYPDF_REQUIREMENTS_SHA256=688a64ece5d89af260f7a8f9e083cd97ebd57bdea826f01d79f6cd09f2d43e99

# --- Tesseract 5.4.0 (built from source; statically linked, self-contained) ---
TESSERACT_VERSION=5.4.0
TESSERACT_SOURCE_URL=https://github.com/tesseract-ocr/tesseract/archive/refs/tags/5.4.0.tar.gz
TESSERACT_SOURCE_SHA256=30ceffd9b86780f01cbf4eaf9b7fc59abddfcbaf5bbd52f9a633c6528cb183fd

